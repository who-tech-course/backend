generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Workspace {
  id              Int           @id @default(autoincrement())
  name            String        @unique
  githubOrg       String
  nicknameRegex   String
  cohortRules     String
  blogSyncEnabled Boolean       @default(true)
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  activityLogs    ActivityLog[]
  cohortRepos     CohortRepo[]
  members         Member[]
  missionRepos    MissionRepo[]
}

model Member {
  id              Int              @id @default(autoincrement())
  githubId        String
  nickname        String?
  manualNickname  String?
  nicknameStats   String?
  avatarUrl       String?
  cohort          Int?
  blog            String?
  rssStatus       String           @default("unknown")
  rssUrl          String?
  rssCheckedAt    DateTime?
  rssError        String?
  roles           String           @default("[\"crew\"]")
  workspaceId     Int
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  blogPosts       BlogPost[]
  blogPostsLatest BlogPostLatest[]
  workspace       Workspace        @relation(fields: [workspaceId], references: [id])
  submissions     Submission[]

  @@unique([githubId, workspaceId])
}

model MissionRepo {
  id               Int          @id @default(autoincrement())
  githubRepoId     Int?         @unique
  name             String
  repoUrl          String
  description      String?
  track            String?
  type             String       @default("individual")
  tabCategory      String       @default("base")
  status           String       @default("active")
  candidateReason  String?
  nicknameRegex    String?
  cohortRegexRules String?
  cohorts          String?
  level            Int?
  syncMode         String       @default("continuous")
  lastSyncAt       DateTime?
  workspaceId      Int
  cohortRepos      CohortRepo[]
  workspace        Workspace    @relation(fields: [workspaceId], references: [id])
  submissions      Submission[]

  @@unique([name, workspaceId])
}

model CohortRepo {
  id            Int         @id @default(autoincrement())
  cohort        Int
  order         Int         @default(0)
  missionRepoId Int
  workspaceId   Int
  workspace     Workspace   @relation(fields: [workspaceId], references: [id])
  missionRepo   MissionRepo @relation(fields: [missionRepoId], references: [id], onDelete: Cascade)

  @@unique([cohort, missionRepoId])
}

model Submission {
  id            Int         @id @default(autoincrement())
  prNumber      Int
  prUrl         String
  title         String
  submittedAt   DateTime
  memberId      Int
  missionRepoId Int
  missionRepo   MissionRepo @relation(fields: [missionRepoId], references: [id])
  member        Member      @relation(fields: [memberId], references: [id])

  @@unique([prNumber, missionRepoId])
}

model BlogPost {
  id          Int      @id @default(autoincrement())
  url         String   @unique
  title       String
  publishedAt DateTime
  memberId    Int
  createdAt   DateTime @default(now())
  member      Member   @relation(fields: [memberId], references: [id])
}

model BlogPostLatest {
  id          Int      @id @default(autoincrement())
  url         String   @unique
  title       String
  publishedAt DateTime
  memberId    Int
  member      Member   @relation(fields: [memberId], references: [id])
}

model ActivityLog {
  id          Int       @id @default(autoincrement())
  type        String
  message     String
  workspaceId Int
  createdAt   DateTime  @default(now())
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
}
