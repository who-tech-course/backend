generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Workspace {
  id            Int           @id @default(autoincrement())
  name          String        @unique
  githubOrg     String
  nicknameRegex String
  cohortRules   String        // JSON: [{"year": 2026, "cohort": 8}, ...]
  members       Member[]
  missionRepos  MissionRepo[]
  createdAt     DateTime      @default(now())
}

model Member {
  id          Int          @id @default(autoincrement())
  githubId    String
  nickname    String?
  cohort      Int?
  blog        String?
  workspaceId Int
  workspace   Workspace    @relation(fields: [workspaceId], references: [id])
  submissions Submission[]
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  @@unique([githubId, workspaceId])
}

model MissionRepo {
  id          Int          @id @default(autoincrement())
  name        String
  repoUrl     String
  workspaceId Int
  workspace   Workspace    @relation(fields: [workspaceId], references: [id])
  submissions Submission[]

  @@unique([name, workspaceId])
}

model Submission {
  id            Int         @id @default(autoincrement())
  prNumber      Int
  prUrl         String
  title         String
  submittedAt   DateTime
  memberId      Int
  missionRepoId Int
  member        Member      @relation(fields: [memberId], references: [id])
  missionRepo   MissionRepo @relation(fields: [missionRepoId], references: [id])

  @@unique([prNumber, missionRepoId])
}
